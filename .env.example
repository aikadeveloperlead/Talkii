# ── Talkii · variables de entorno ──
# Copia este archivo a `.env.local` y rellena los valores reales.
# `.env.local` está en .gitignore — NUNCA subas credenciales al repo.

# URL del proyecto Supabase (Project Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave pública anónima (Project Settings → API → anon public).
# Segura para el navegador; RLS protege los datos.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clave service-role (Project Settings → API → service_role). SALTA RLS.
# SOLO en el servidor (webhooks/jobs). NUNCA la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Razonamiento (Decision Engine · AA-02) ──
# Clave de la Anthropic Messages API. Solo servidor. Requerida para MakeDecision.
ANTHROPIC_API_KEY=sk-ant-...
# Modelo Claude por defecto del proveedor de razonamiento (opcional).
ANTHROPIC_MODEL=claude-sonnet-5

# ── Conexión directa a Postgres (migraciones / DDL) ──
# Session pooler (:5432) para DDL; transaction pooler (:6543) para runtime.
# Nota SSL: usar rejectUnauthorized:false; NO añadir ?sslmode=require.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-us-east-2.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-us-east-2.pooler.supabase.com:5432/postgres
